# ── Discord ───────────────────────────────────────────────────────────────────
BOT_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_guild_id_here

# Comma-separated Discord user IDs of main (hard-coded) admins
MAIN_ADMIN_IDS=123456789,987654321

# ── Pterodactyl ───────────────────────────────────────────────────────────────
PANEL_URL=https://panel.yourdomain.com
PANEL_API_KEY=ptla_xxxxxxxxxxxxxxxxxxxx

# Optional: public status page URL (shown in node embed buttons)
STATUS_URL=https://status.yourdomain.com

# Optional: support URL shown in server-ready DM buttons
SUPPORT_URL=https://discord.gg/yoursupportserver

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# ── Behaviour ─────────────────────────────────────────────────────────────────
# How often (in seconds) the node monitor polls for status updates
NODE_POLL_INTERVAL=45
